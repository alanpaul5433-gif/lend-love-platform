{
  "expo": {
    "name": "Lend Love",
    "slug": "lend-love",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "lendlove",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "bundleIdentifier": "com.lendlove.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Lend Love uses the camera to verify your identity during KYC.",
        "NSPhotoLibraryUsageDescription": "Lend Love accesses your photos to upload documents for identity verification.",
        "NSFaceIDUsageDescription": "Lend Love uses Face ID to securely log you in.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.lendlove.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "USE_BIOMETRIC", "USE_FINGERPRINT"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Lend Love accesses your photos to upload documents for identity verification.",
          "cameraPermission": "Lend Love uses the camera to verify your identity during KYC."
        }
      ]
    ],
    "experiments": { "typedRoutes": true },
    "extra": {
      "demoMode": true
    }
  }
}
