{
  "expo": {
    "name": "Lend Love",
    "slug": "lend-love",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "lendlove",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.lendlove.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Lend Love uses the camera to verify your identity during KYC.",
        "NSPhotoLibraryUsageDescription": "Lend Love accesses your photos to upload documents for identity verification.",
        "NSFaceIDUsageDescription": "Lend Love uses Face ID to securely log you in.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.lendlove.app",
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Lend Love accesses your photos to upload documents for identity verification.",
          "cameraPermission": "Lend Love uses the camera to verify your identity during KYC."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "demoMode": true,
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "6a09469e-b57d-4344-9dae-5ab2099348d6"
      }
    },
    "owner": "alanp007"
  }
}
