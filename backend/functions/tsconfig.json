{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "lib",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@lendlove/shared": ["../../shared/src"]
    }
  },
  "include": ["src/**/*", "../../shared/src/**/*"],
  "exclude": ["node_modules", "lib", "scripts"]
}
