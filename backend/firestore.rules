rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ====== Helpers ======
    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // Demo mode: also check Firestore user doc since custom claims need Blaze.
    // Production: relies on the `role` custom claim (set by Cloud Function).
    function isAdmin() {
      return isAuthed() && (
        request.auth.token.role == 'admin' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isDemoUser() {
      return isAuthed() && request.auth.token.demo == true;
    }

    function isVerified() {
      return isAuthed() && (request.auth.token.kycVerified == true || isDemoUser());
    }

    // ====== Users ======
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin() || isAuthed();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isOwner(uid) || isAdmin();
    }

    // ====== Loans ======
    match /loans/{loanId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
                    && request.resource.data.loanerId == request.auth.uid;
      allow update: if isAuthed()
                    && (resource.data.loanerId == request.auth.uid
                        || resource.data.borrowerId == request.auth.uid
                        || isAdmin());
      allow delete: if isAdmin();
    }

    // ====== Loan Requests ======
    match /loanRequests/{requestId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
                    && request.resource.data.borrowerId == request.auth.uid;
      allow update: if isAuthed()
                    && (resource.data.borrowerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ====== Agreements ======
    // Demo mode: parties of the agreement may create and update their own
    // signature fields. Production will route through Cloud Functions for
    // PDF generation + audit logging.
    match /agreements/{agreementId} {
      allow read: if isAuthed()
                  && (resource.data.loanerId == request.auth.uid
                      || resource.data.borrowerId == request.auth.uid
                      || isAdmin());
      allow create: if isAuthed()
                    && (request.resource.data.loanerId == request.auth.uid
                        || request.resource.data.borrowerId == request.auth.uid);
      allow update: if isAuthed()
                    && (resource.data.loanerId == request.auth.uid
                        || resource.data.borrowerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ====== Transactions ======
    match /transactions/{txId} {
      allow read: if isAuthed()
                  && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false; // Cloud Functions only
    }

    // ====== Conversations + Messages ======
    match /conversations/{convId} {
      allow read: if isAuthed()
                  && request.auth.uid in resource.data.participantIds;
      allow create: if isAuthed()
                    && request.auth.uid in request.resource.data.participantIds;
      allow update: if isAuthed()
                    && request.auth.uid in resource.data.participantIds;
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if isAuthed()
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participantIds;
        allow create: if isAuthed()
                      && request.resource.data.senderId == request.auth.uid;
        allow update: if isAuthed()
                      && (resource.data.senderId == request.auth.uid || isAdmin());
        allow delete: if isAdmin();
      }
    }

    // ====== KYC Submissions ======
    match /kycSubmissions/{submissionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthed()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ====== Notifications ======
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.userId);
      allow update: if isOwner(resource.data.userId);
      allow create, delete: if false;
    }

    // ====== Support Tickets ======
    match /supportTickets/{ticketId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthed()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // ====== Admin Audit Log ======
    // Demo: admins write directly. Production: Cloud Function only.
    match /adminActions/{actionId} {
      allow read: if isAdmin();
      allow create: if isAdmin()
                    && request.resource.data.adminId == request.auth.uid;
      allow update, delete: if false;
    }

    // ====== Platform Config ======
    match /config/{configKey} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // ====== Reports (user-flagged content) ======
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthed()
                    && request.resource.data.reporterId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ====== Block list (subcollection of user) ======
    match /users/{uid}/blockedUsers/{blockedUid} {
      allow read, write: if isOwner(uid);
    }
  }
}
